{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run current Python file as module",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/_run_as_module.py",
      "args": ["${file}"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ]
}